    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "4.1.7"
  },
  "packageManager": "pnpm@9.5.0",
  "volta": {
    "node": "22.16.0",
    "pnpm": "9.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.1.8",
    "@tailwindcss/typography": "0.5.16",
    "@types/node": "22.15.21",
